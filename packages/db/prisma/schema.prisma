generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum TicketingMode {
  GA
  RESERVED
}

enum SeatStatus {
  AVAILABLE
  RESERVED
  SOLD
  BLOCKED
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
}

enum PaymentProvider {
  STRIPE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
}

enum CheckInStatus {
  NOT_CHECKED_IN
  CHECKED_IN
}

enum NotificationSeverity {
  INFO
  WARNING
  CRITICAL
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum PaymentAttemptStatus {
  STARTED
  FAILED
  SUCCEEDED
  BLOCKED
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  password       String
  role           Role     @default(USER)
  createdAt      DateTime @default(now())
  orders         Order[]
  tickets        Ticket[]
  reviewedOrders Order[]  @relation("OrderReviewer")
}

model Venue {
  id        String   @id @default(cuid())
  name      String
  location  String
  createdAt DateTime @default(now())
  events    Event[]
}

model Event {
  id            String        @id @default(cuid())
  title         String
  description   String
  date          DateTime
  venueId       String
  ticketingMode TicketingMode @default(GA)
  createdAt     DateTime      @default(now())
  venue         Venue         @relation(fields: [venueId], references: [id], onDelete: Cascade)
  ticketTiers   TicketTier[]
  seatSections  SeatSection[]
  orders        Order[]
  tickets       Ticket[]
  paymentAttempts PaymentAttempt[]
  notifications AdminNotification[]
}

model TicketTier {
  id         String      @id @default(cuid())
  eventId    String
  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name       String
  price      Decimal     @db.Decimal(10, 2)
  quantity   Int
  orderItems OrderItem[]
  tickets    Ticket[]
}

model SeatSection {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name      String
  color     String?
  createdAt DateTime @default(now())
  rows      SeatRow[]
}

model SeatRow {
  id        String    @id @default(cuid())
  sectionId String
  section   SeatSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  label     String
  sortOrder Int
  seats     Seat[]
}

model Seat {
  id         String      @id @default(cuid())
  rowId      String
  row        SeatRow     @relation(fields: [rowId], references: [id], onDelete: Cascade)
  seatNumber String
  label      String?
  x          Int
  y          Int
  price      Decimal     @db.Decimal(10, 2)
  status     SeatStatus  @default(AVAILABLE)
  orderItems OrderItem[]
  tickets    Ticket[]

  @@unique([rowId, seatNumber])
}

model Order {
  id               String      @id @default(cuid())
  userId           String?
  email            String?
  eventId          String
  totalAmount      Decimal     @db.Decimal(10, 2)
  status           OrderStatus @default(PENDING)
  riskLevel        RiskLevel   @default(LOW)
  fraudFlags       Json?
  flaggedAt        DateTime?
  ipAddress        String?
  userAgent        String?
  reviewedAt       DateTime?
  reviewedByUserId String?
  reviewNotes      String?
  createdAt        DateTime    @default(now())
  user             User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  event            Event       @relation(fields: [eventId], references: [id], onDelete: Restrict)
  reviewedBy       User?       @relation("OrderReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  items            OrderItem[]
  payment          Payment?
  tickets          Ticket[]
  notifications    AdminNotification[]

  @@index([eventId])
  @@index([userId])
  @@index([riskLevel])
  @@index([flaggedAt])
  @@index([reviewedAt])
  @@index([reviewedByUserId])
}

model OrderItem {
  id           String     @id @default(cuid())
  orderId      String
  ticketTierId String?
  seatId       String?
  quantity     Int        @default(1)
  price        Decimal    @db.Decimal(10, 2)
  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  ticketTier   TicketTier? @relation(fields: [ticketTierId], references: [id], onDelete: SetNull)
  seat         Seat?      @relation(fields: [seatId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([ticketTierId])
  @@index([seatId])
}

model Payment {
  id              String          @id @default(cuid())
  orderId         String          @unique
  provider        PaymentProvider @default(STRIPE)
  paymentIntentId String          @unique
  amount          Decimal         @db.Decimal(10, 2)
  status          PaymentStatus   @default(PENDING)
  providerResponseCode String?
  failureReason   String?
  createdAt       DateTime        @default(now())
  order           Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Ticket {
  id            String        @id @default(cuid())
  orderId       String
  eventId       String
  userId        String?
  seatId        String?
  ticketTierId  String?
  code          String        @unique
  qrCodeData    String?
  status        TicketStatus  @default(ACTIVE)
  checkInStatus CheckInStatus @default(NOT_CHECKED_IN)
  checkedInAt   DateTime?
  issuedAt      DateTime      @default(now())
  attendeeName  String?
  order         Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  event         Event         @relation(fields: [eventId], references: [id], onDelete: Restrict)
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  seat          Seat?         @relation(fields: [seatId], references: [id], onDelete: SetNull)
  ticketTier    TicketTier?   @relation(fields: [ticketTierId], references: [id], onDelete: SetNull)
  notifications AdminNotification[]

  @@index([orderId])
  @@index([eventId])
  @@index([userId])
  @@index([checkInStatus])
}

model PaymentAttempt {
  id        String               @id @default(cuid())
  email     String?
  ipAddress String?
  eventId   String?
  status    PaymentAttemptStatus
  reason    String?
  createdAt DateTime             @default(now())
  event     Event?               @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([ipAddress])
  @@index([eventId])
  @@index([status])
  @@index([createdAt])
}

model AdminNotification {
  id             String               @id @default(cuid())
  type           String
  severity       NotificationSeverity
  title          String
  message        String
  relatedOrderId String?
  relatedEventId String?
  relatedTicketId String?
  dedupeKey      String?
  readAt         DateTime?
  createdAt      DateTime             @default(now())
  order          Order?               @relation(fields: [relatedOrderId], references: [id], onDelete: SetNull)
  event          Event?               @relation(fields: [relatedEventId], references: [id], onDelete: SetNull)
  ticket         Ticket?              @relation(fields: [relatedTicketId], references: [id], onDelete: SetNull)

  @@index([type])
  @@index([severity])
  @@index([readAt])
  @@index([createdAt])
  @@index([relatedOrderId])
  @@index([relatedEventId])
  @@index([relatedTicketId])
  @@index([dedupeKey])
}

model SystemEvent {
  id         String   @id @default(cuid())
  type       String
  entityType String
  entityId   String
  message    String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([entityType, entityId])
  @@index([createdAt])
}
